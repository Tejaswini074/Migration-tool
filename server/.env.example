PORT=5000

# Comma-separated list of allowed frontend origins, e.g. https://app.example.com
# Leave blank for local dev (reflects the request origin). Set this in production.
CORS_ORIGIN=

# Dedicated app database (stores users/roles/projects - independent of migration source/destination DBs)
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_USER=root
APP_DB_PASSWORD=
APP_DB_NAME=databridge_app

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Closed by default: self-service signup (POST /auth/signup) is disabled, so only an admin can
# create new accounts (Admin Users page). Set to "true" to let anyone create their own account.
# Does not affect the one-time first-admin bootstrap (POST /auth/register).
ALLOW_OPEN_SIGNUP=false

# Used to build the link inside password-reset emails (the client's origin).
APP_URL=http://localhost:5173

# Optional: sends password-reset emails via SMTP. Leave unset in dev - the reset link is
# logged to the server console instead, so forgot-password still works end to end locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DataBridge <no-reply@databridge.local>

# Encrypts scheduled-migration credentials at rest (the one place DataBridge stores DB
# credentials - everywhere else connections are live-only). Only required if you use
# the Schedules feature. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=
