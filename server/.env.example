PORT=5000

# Comma-separated list of allowed frontend origins, e.g. https://app.example.com
# Leave blank for local dev (reflects the request origin). Set this in production.
CORS_ORIGIN=

# Dedicated app database (stores users/roles/projects - independent of migration source/destination DBs)
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_USER=root
APP_DB_PASSWORD=
APP_DB_NAME=databridge_app

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Encrypts scheduled-migration credentials at rest (the one place DataBridge stores DB
# credentials - everywhere else connections are live-only). Only required if you use
# the Schedules feature. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=
